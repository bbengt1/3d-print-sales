      "id": "11111111-1111-1111-1111-111111111010",
      "name": "SSH: Diff migrations",
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "position": [2160, 400],
      "credentials": {
        "sshPrivateKey": {
