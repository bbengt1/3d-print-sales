      "parameters": {
        "resource": "command",
        "command": "=cd /srv/3d-print-sales/repo && git diff --name-only {{ $('SSH: Capture before SHA').item.json.stdout.trim() }} {{ $('SSH: Capture after SHA').item.json.stdout.trim() }} -- backend/alembic/versions/ 2>/dev/null || true"
