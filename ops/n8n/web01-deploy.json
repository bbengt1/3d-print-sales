    {
      "parameters": {
        "resource": "command",
        "command": "cd /srv/3d-print-sales/repo && scripts/web01-compose.sh ps --format json"
      },
      "id": "11111111-1111-1111-1111-111111111016",
      "name": "SSH: Compose ps",
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "position": [3600, 400],
      "credentials": {
        "sshPrivateKey": {
          "name": "web01.bengtson.local"
        }
      },
      "onError": "continueErrorOutput"
