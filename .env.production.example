# Copy this file to a server-side env file such as:
# /srv/3d-print-sales/env/web01.env
#
# Do not commit real production secrets.

# Database
DB_USER=printuser
DB_PASSWORD=replace-with-strong-db-password
DB_NAME=printsales

# Backend auth/app secrets
SECRET_KEY=replace-with-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App environment
ENVIRONMENT=production
TESTING=false
AUTO_CREATE_SCHEMA=false

# Backend CORS
# Update this to the actual app origin once ingress is finalized.
BACKEND_CORS_ORIGINS=["http://web01.bengtson.local"]

# Admin seed account
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-admin-password

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=20
